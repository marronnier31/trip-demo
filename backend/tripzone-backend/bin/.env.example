# Spring profile
SPRING_PROFILES_ACTIVE=local

# Server
SERVER_PORT=8080

# Session / cookie
SESSION_COOKIE_NAME=TRIPZONESESSION
SESSION_COOKIE_SAME_SITE=Lax
SESSION_COOKIE_SECURE=false
SESSION_TIMEOUT=30m

# CORS
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://localhost:5174

# JPA common
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
JPA_DDL_AUTO=update
JPA_OPEN_IN_VIEW=false
JPA_DEFAULT_BATCH_FETCH_SIZE=100

# --------------------------------------------------
# Oracle profile example
# local -> oracle 전환 시 SPRING_PROFILES_ACTIVE=oracle 로 변경
# 아래 값은 Oracle Free / XE 계열 기본 예시
# --------------------------------------------------
DB_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
DB_URL=jdbc:oracle:thin:@localhost:1521/FREEPDB1
DB_USERNAME=tripzone
DB_PASSWORD=tripzone
DB_SCHEMA=TRIPZONE
JPA_DATABASE_PLATFORM=org.hibernate.dialect.OracleDialect

# --------------------------------------------------
# Optional: H2 override example for local profile
# 기본 local profile 은 application-local.properties 값을 사용하므로
# 보통 아래 값은 건드릴 필요 없다.
# --------------------------------------------------
# DB_DRIVER_CLASS_NAME=org.h2.Driver
# DB_URL=jdbc:h2:mem:tripzone;MODE=Oracle;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
# DB_USERNAME=sa
# DB_PASSWORD=
